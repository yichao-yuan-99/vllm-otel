# Image/container naming (compose services)
VLLM_IMAGE_NAME=yichaoyuan/vllm-openai-otel-lp
VLLM_CONTAINER_NAME=vllm-openai-otel-lp

# Host gateway runtime (gateway is NOT launched by docker compose)
GATEWAY_PORT=11457
GATEWAY_OUTPUT_ROOT=./tests/output/gateway-artifacts
GATEWAY_OTEL_SERVICE_NAME=vllm-gateway
GATEWAY_OTEL_EXPORTER_OTLP_TRACES_INSECURE=true
GATEWAY_OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=grpc://127.0.0.1:4317
GATEWAY_JAEGER_API_BASE_URL=http://127.0.0.1:16686/api/traces
GATEWAY_REQUEST_TIMEOUT_SECONDS=120
GATEWAY_ARTIFACT_COMPRESSION=none
GATEWAY_JOB_END_TRACE_WAIT_SECONDS=10

# vLLM runtime config
VLLM_SERVICE_PORT=11451
# Required: set both values for your model
VLLM_MODEL_NAME=Qwen/Qwen3-Coder-30B-A3B-Instruct
VLLM_SERVED_MODEL_NAME=Qwen3-Coder-30B-A3B-Instruct
VLLM_TENSOR_PARALLEL_SIZE=2

# GPU selection: examples -> 0 | 0,1 | 2,3
VLLM_VISIBLE_DEVICES=2,3

# OpenTelemetry (vLLM container -> jaeger container)
OTEL_SERVICE_NAME=vllm-server
OTEL_EXPORTER_OTLP_TRACES_INSECURE=true
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=grpc://jaeger:4317
VLLM_COLLECT_DETAILED_TRACES=all
OTEL_TEST_SERVICE_NAME=otel-smoke-client

# Custom logits processor loaded at server startup.
# Safe by default for normal requests; it only activates when
# vllm_xargs.forced_token_ids is provided by a request.
VLLM_LOGITS_PROCESSORS=forceSeq.force_sequence_logits_processor:ForceSequenceAdapter

# Optional text used by the force-sequence smoke test.
VLLM_FORCE_SEQUENCE_TEST_TEXT=FORCE_SEQ_SMOKE_OK

# Optional: pass trust_remote_code=True when bootstrap resolves tokenizer EOS id.
VLLM_FORCE_SEQ_TRUST_REMOTE_CODE=false

# Optional: timeout used by docker/tests smoke test (seconds)
VLLM_STARTUP_TIMEOUT=600

# HF_HOME / HF_HUB_CACHE / HF_TOKEN come from your current shell environment.
# Export them before running docker compose.
