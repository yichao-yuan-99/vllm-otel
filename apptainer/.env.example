# Directory where SIF files are stored.
APPTAINER_IMGS=${HOME}/apptainer-images

# OCI images to convert into SIFs.
JAEGER_IMAGE=docker://jaegertracing/all-in-one:1.57
VLLM_IMAGE=docker://yichaoyuan/vllm-openai-otel:v0.14.1-otel-lp-rocm

# Optional explicit SIF paths (defaults are under APPTAINER_IMGS).
# JAEGER_SIF=${APPTAINER_IMGS}/jaeger-all-in-one-1.57.sif
# VLLM_SIF=${APPTAINER_IMGS}/vllm-openai-otel-v0.14.1-otel-lp-rocm.sif

# HF variables are expected to be exported in the parent shell.
# Uncomment only if you want to override them in this file.
# HF_HOME=/path/to/hf-home
# HF_HUB_CACHE=/path/to/hf-hub-cache
# HF_TOKEN=

# vLLM runtime
VLLM_SERVICE_PORT=11451
VLLM_MODEL_NAME=Qwen/Qwen3-Coder-30B-A3B-Instruct
VLLM_SERVED_MODEL_NAME=Qwen3-Coder-30B-A3B-Instruct
VLLM_TENSOR_PARALLEL_SIZE=8

# MI325X x8 default. Example: 0,1,2,3,4,5,6,7
VLLM_VISIBLE_DEVICES=0,1,2,3,4,5,6,7

# OpenTelemetry settings (vLLM -> local Jaeger)
OTEL_SERVICE_NAME=vllm-server
OTEL_EXPORTER_OTLP_TRACES_INSECURE=true
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=grpc://127.0.0.1:4317
VLLM_COLLECT_DETAILED_TRACES=all
OTEL_TEST_SERVICE_NAME=otel-smoke-client

# Force-sequence logits processor
VLLM_LOGITS_PROCESSORS=forceSeq.force_sequence_logits_processor:ForceSequenceAdapter
VLLM_FORCE_SEQ_TRUST_REMOTE_CODE=false
VLLM_FORCE_SEQUENCE_TEST_TEXT=FORCE_SEQ_SMOKE_OK

# Startup timeout used by smoke tests and health checks (seconds)
VLLM_STARTUP_TIMEOUT=900

# Optional scratch/cache locations (recommended if home disk is tight).
# Defaults are under ${TMPDIR:-/tmp} when unset.
# AITER_JIT_DIR=/tmp/vllm-aiter-jit-${USER}
# VLLM_RUNTIME_ROOT=/tmp/vllm-runtime-${USER}
# XDG_CACHE_HOME=${VLLM_RUNTIME_ROOT}/xdg-cache
# VLLM_CACHE_ROOT=${XDG_CACHE_HOME}/vllm

# Jaeger API base used by tracing checks
JAEGER_API_BASE_URL=http://127.0.0.1:16686/api/traces
